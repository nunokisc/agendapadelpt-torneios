generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Tournament {
  id          String   @id @default(cuid())
  slug        String   @unique
  adminToken  String   @unique
  name        String
  description String?
  format      String
  status      String   @default("draft")
  matchFormat String   @default("M3SPO")
  starPoint   Boolean  @default(false)
  thirdPlace  Boolean  @default(false)
  groupCount  Int?
  advanceCount Int?
  isPublic         Boolean @default(false)
  registrationOpen Boolean @default(false)
  courtCount       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  players       Player[]
  matches       Match[]
  registrations Registration[]
}

model Player {
  id           String  @id @default(cuid())
  name         String
  player1Name  String  @default("")
  player2Name  String  @default("")
  seed         Int?
  checkedIn    Boolean @default(true)
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  groupIndex   Int?

  matchesAsTeam1 Match[] @relation("Team1")
  matchesAsTeam2 Match[] @relation("Team2")
  matchWinners   Match[] @relation("Winner")
}

model Match {
  id            String  @id @default(cuid())
  tournamentId  String
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  round         Int
  position      Int
  bracketType   String  @default("winners")
  groupIndex    Int?

  team1Id       String?
  team1         Player? @relation("Team1", fields: [team1Id], references: [id])
  team2Id       String?
  team2         Player? @relation("Team2", fields: [team2Id], references: [id])
  winnerId      String?
  winner        Player? @relation("Winner", fields: [winnerId], references: [id])

  scores        String?
  scheduledAt   DateTime?
  court         String?

  status        String  @default("pending")

  nextMatchId      String?
  nextMatchSlot    Int?
  loserNextMatchId String?
  loserNextSlot    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Registration {
  id           String   @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player1Name  String
  player2Name  String
  teamName     String?
  contact      String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}
