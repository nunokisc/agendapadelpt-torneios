# ── Base de dados ─────────────────────────────────────────────────────────────
# Escolhe UMA das opções abaixo e corre: npm run db:setup

# SQLite — padrão, funciona em dev e produção sem servidor de base de dados
DATABASE_URL="file:./dev.db"

# MySQL / MariaDB — alternativa para quem prefere um servidor de base de dados dedicado
# DATABASE_URL="mysql://user:password@localhost:3306/padel_torneios"
# DATABASE_URL="mariadb://user:password@localhost:3306/padel_torneios"

# ── Administração da plataforma ───────────────────────────────────────────────
PLATFORM_ADMIN_TOKEN=padel-admin-2025
